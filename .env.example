# =============================================================================
# MVR CONSULTANTS — ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file
# =============================================================================

# =============================================================================
# DATABASE — Supabase PostgreSQL
# =============================================================================
# Format: postgresql://user:password@host:port/database?pgbouncer=true
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Direct connection (for migrations, bypasses PgBouncer)
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# =============================================================================
# AUTHENTICATION — JWT
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters-long
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=30

# =============================================================================
# SERVER CONFIG
# =============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
RUST_LOG=info
ENVIRONMENT=development

# =============================================================================
# FRONTEND / CORS
# =============================================================================
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# =============================================================================
# FILE UPLOADS — Cloudinary
# =============================================================================
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_UPLOAD_PRESET=mvr_consultants

# =============================================================================
# EMAIL — Resend
# =============================================================================
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@mvrconsultants.com
EMAIL_FROM_NAME=MVR Consultants

# =============================================================================
# REDIS (Optional — Phase 5)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# ADMIN
# =============================================================================
ADMIN_EMAIL=admin@mvrconsultants.com
ADMIN_PASSWORD=change-this-in-production

# =============================================================================
# NEXT.JS PUBLIC VARIABLES (prefixed with NEXT_PUBLIC_)
# These are exposed to the browser — DO NOT put secrets here
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MVR Consultants
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name

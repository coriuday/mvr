# =============================================================================
# MVR Consultants — ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# HOW TO SET UP FOR LOCAL DEVELOPMENT:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in all the values marked with <...>
#   3. Run Docker:      docker-compose up --build
#
# ⚠️  NEVER commit the actual .env file (it's in .gitignore)
# ⚠️  This template IS committed — keep it up to date when adding new variables
#
# WHO NEEDS WHAT:
#   - docker-compose users: fill in this entire file at the ROOT level
#   - Local dev (no Docker): copy backend/.env.example → backend/.env
# =============================================================================

# =============================================================================
# DATABASE — Supabase PostgreSQL
# =============================================================================
# Get from: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "Transaction" pooler URL (port 5432) — NOT the direct connection
DATABASE_URL=postgresql://postgres.<YOUR-PROJECT-REF>:<YOUR-DB-PASSWORD>@aws-<REGION>.pooler.supabase.com:5432/postgres

# =============================================================================
# AUTHENTICATION — JWT
# =============================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET=<minimum-32-character-random-hex-string>
JWT_REFRESH_SECRET=<minimum-32-character-random-hex-string-different-from-above>
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=30

# =============================================================================
# SERVER CONFIG
# =============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
RUST_LOG=info
ENVIRONMENT=development

# =============================================================================
# FRONTEND / CORS
# =============================================================================
FRONTEND_URL=http://localhost:3000
# In Docker: traffic goes through nginx on port 80
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost

# =============================================================================
# REDIS — Required for JWT token revocation (logout blacklist)
# In docker-compose, Redis runs as a container. Just pick a strong password.
# =============================================================================
REDIS_PASSWORD=<choose-a-strong-redis-password>

# =============================================================================
# FILE UPLOADS — Cloudinary
# =============================================================================
# Get from: Cloudinary Dashboard → Settings → Access Keys
CLOUDINARY_CLOUD_NAME=<your-cloudinary-cloud-name>
CLOUDINARY_API_KEY=<your-cloudinary-api-key>
CLOUDINARY_API_SECRET=<your-cloudinary-api-secret>
# Must be a SIGNED upload preset (not unsigned) — create in Cloudinary dashboard
CLOUDINARY_UPLOAD_PRESET=mvr_consultants

# =============================================================================
# EMAIL — Resend
# =============================================================================
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_<your-resend-api-key>
EMAIL_FROM=noreply@mvrconsultants.org
EMAIL_FROM_NAME=MVR Consultants
# Admin notification email addresses (required — backend will refuse to start without these)
ADMIN_EMAIL=<hyderabad-office-email@example.com>
ADMIN_EMAIL_GUNTUR=<guntur-office-email@example.com>

# =============================================================================
# AI — Gemini Flash (used for SOP review feature)
# =============================================================================
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<your-gemini-api-key>

# =============================================================================
# NEXT.JS PUBLIC VARIABLES (prefixed with NEXT_PUBLIC_)
# These are exposed to the browser — DO NOT put secrets here
# =============================================================================
# In Docker: nginx is on port 80, so the API URL is http://localhost:80
# Without Docker: direct Rust server on port 8081
NEXT_PUBLIC_API_URL=http://localhost:80
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=<your-cloudinary-cloud-name>

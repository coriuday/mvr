# Rust build outputs — NEVER commit these
target/

# Compiled object files
*.o
*.a
*.so
*.dylib

# Rust source backups (created by rustfmt)
**/*.rs.bk

# SQLx offline cache (can optionally commit for offline CI)
# .sqlx/

# Environment variables
.env
.env.local
.env.production

# Editor files
.vscode/
.idea/
*.swp

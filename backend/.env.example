# =============================================================================
# Backend Environment Variables Template
# Copy to .env (local dev) or set in Render Dashboard (production)
# NEVER commit the actual .env file — only this .env.example
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
PORT=8080
RUST_LOG=info
ENVIRONMENT=production

# ── JWT ───────────────────────────────────────────────────────────────────────
# Minimum 32 characters each — generate with: openssl rand -base64 48
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=30

# ── CORS (must exactly match the browser's Origin header) ────────────────────
FRONTEND_URL=https://www.mvrconsultants.org
ALLOWED_ORIGINS=https://www.mvrconsultants.org

# ── Redis — JTI Blocklist (C-1 security fix) ─────────────────────────────────
# Required in production: ensures revoked tokens survive backend restarts.
# On Render: provision a Redis instance and paste the Internal/External URL here.
# Format: redis://:[PASSWORD]@[HOST]:[PORT]
# Leave unset for local dev without Docker (falls back to in-memory with a warning).
REDIS_PASSWORD=your-redis-password
REDIS_URL=redis://:your-redis-password@redis:6379

# ── Cloudinary (image uploads — H-2 security fix) ────────────────────────────
# IMPORTANT: The upload preset MUST be set to "Signed" mode in the Cloudinary
# dashboard (https://console.cloudinary.com → Settings → Upload Presets).
# Using an unsigned preset allows anyone to upload arbitrary files to MVR storage.
# The backend generates signed upload signatures via POST /api/admin/cloudinary/sign.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret    # NEVER expose this; server-side only
CLOUDINARY_UPLOAD_PRESET=mvr_consultants  # Must be SIGNED in Cloudinary dashboard

# ── Email — Resend (https://resend.com) ───────────────────────────────────────
RESEND_API_KEY=re_your_api_key
# Must be a verified sender domain in Resend dashboard
EMAIL_FROM=noreply@mvrconsultants.org
EMAIL_FROM_NAME=MVR Consultants
# L-2 security fix: admin emails are now REQUIRED — no defaults in source code.
# Both ADMIN_EMAIL and ADMIN_EMAIL_GUNTUR must be set (server fails to start if missing).
ADMIN_EMAIL=your-hyderabad-admin@example.com
ADMIN_EMAIL_GUNTUR=your-guntur-admin@example.com

# ── AI — Google Gemini (SOP reviewer) ────────────────────────────────────────
# Get key at https://aistudio.google.com/app/apikey
# Free tier: 15 req/min · Paid: ~$0.0003/SOP review (Gemini 1.5 Flash)
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

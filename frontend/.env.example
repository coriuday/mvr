# =============================================================================
# Frontend Environment Variables Template
# Copy to .env.local (NEVER commit .env.local)
# =============================================================================

# Backend API URL (server-only: SSR + Next.js rewrites proxy to Rust backend)
# On Vercel set to: https://mvr-backend.onrender.com
BACKEND_URL=http://localhost:8080

# Public site URL (browser uses same-origin /api/* — no direct Render URL needed)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
